{
  "rewrites": [
    {
      "source": "/",
      "destination": "/ap3x/demo/index.html"
    },
    {
      "source": "/owner",
      "destination": "/ap3x/demo/owner-demo.html"
    },
    {
      "source": "/pwa/:path",
      "destination": "/ap3x/companion/:path"
    },
    {
      "source": "/pwa",
      "destination": "/ap3x/companion/index.html"
    },
    {
      "source": "/course",
      "destination": "/ap3x/companion/course-view.html"
    },
    {
      "source": "/courses",
      "destination": "/ap3x/companion/course-picker.html"
    },
    {
      "source": "/trainer",
      "destination": "/ap3x/demo/trainer-demo.html"
    },
    {
      "source": "/manifest.json",
      "destination": "/ap3x/demo/manifest.json"
    },
    {
      "source": "/sw.js",
      "destination": "/ap3x/demo/sw.js"
    },
    {
      "source": "/fp-courses.js",
      "destination": "/fp-courses.js"
    },
    {
      "source": "/icons/:file",
      "destination": "/icons/:file"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}